{
    "identifier": "me.missuo.deeplx.translate",
    "category": "translate",
    "version": "2.0.0",
    "name": "DeepL X",
    "summary": "Plugin based on OwO-Network/DeepLX",
    "author": "missuo",
    "appcast": "https://github.com/daxiong888/bob-plugin-deeplx/raw/main/appcast.json",
    "homepage": "https://github.com/daxiong888/bob-plugin-deeplx",
    "icon": "icon.png",
    "minBobVersion": "0.5.0",
    "options": [
        {
            "identifier": "url",
            "type": "text",
            "title": "API",
            "defaultValue": "http://localhost:1188/translate",
            "desc": "DeepLX 接口地址，支持填写多个地址，用英文逗号或换行分隔，插件会按顺序自动切换。",
            "textConfig": {
                "type": "visible"
            }
        },
        {
            "identifier": "token",
            "type": "text",
            "title": "Token",
            "desc": "如果你在服务端没有设置，请留空。",
            "defaultValue": ""
        },
        {
            "identifier": "timeout",
            "type": "text",
            "title": "Timeout",
            "desc": "单个接口请求超时时间，单位秒，范围 3-30，默认 8。",
            "defaultValue": "8",
            "textConfig": {
                "type": "visible"
            }
        },
        {
            "identifier": "alternatives",
            "type": "menu",
            "title": "Alternatives",
            "desc": "显示 DeepLX 返回的候选译文。短文本场景常出现多条近似结果，默认关闭。",
            "defaultValue": "2",
            "menuValues": [
                {
                    "title": "开启",
                    "value": "1"
                },
                {
                    "title": "关闭",
                    "value": "2"
                }
            ]
        },
        {
            "identifier": "lineBreakMode",
            "type": "menu",
            "title": "Render Mode",
            "desc": "Smart Paragraphs 会合并普通正文，但会保留列表、代码块、URL 和命令行；Preserve Formatting 会按原始换行和列表结构显示。",
            "defaultValue": "smart",
            "menuValues": [
                {
                    "title": "Smart Paragraphs",
                    "value": "smart"
                },
                {
                    "title": "Preserve Formatting",
                    "value": "format"
                }
            ]
        },
        {
            "identifier": "aiPostProcess",
            "type": "menu",
            "title": "AI Post-Process",
            "desc": "对 DeepLX 译文进行 AI 二次处理（需填写 AI API Key）。Translation Polish 修正翻译中的错译和不自然表达；Full Refine 更大幅度地润色重组，使译文接近母语表达。两种模式均会自动修复 OCR 断行。短文本自动跳过 AI 处理。失败时自动回退原始译文。",
            "defaultValue": "off",
            "menuValues": [
                {
                    "title": "关闭",
                    "value": "off"
                },
                {
                    "title": "Translation Polish",
                    "value": "auto"
                },
                {
                    "title": "Full Refine",
                    "value": "polish"
                }
            ]
        },
        {
            "identifier": "aiApiKey",
            "type": "text",
            "title": "AI API Key",
            "desc": "OpenRouter API Key（在 openrouter.ai 获取）。仅 AI Post-Process 开启时需要填写。",
            "defaultValue": ""
        },
        {
            "identifier": "aiModel",
            "type": "text",
            "title": "AI Model",
            "desc": "留空使用默认模型 google/gemini-2.5-flash-lite。可在 openrouter.ai/models 查看完整模型列表。",
            "defaultValue": "",
            "textConfig": {
                "type": "visible"
            }
        }
    ]
}
