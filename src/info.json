{
    "identifier": "me.missuo.deeplx.translate",
    "category": "translate",
    "version": "1.0.12",
    "name": "DeepL X",
    "summary": "Plugin based on OwO-Network/DeepLX",
    "author": "missuo",
    "appcast": "https://github.com/missuo/bob-plugin-deeplx/raw/main/appcast.json",
    "homepage": "https://github.com/missuo/bob-plugin-deeplx",
    "icon": "icon.png",
    "minBobVersion": "0.5.0",
    "options": [
        {
            "identifier": "url",
            "type": "text",
            "title": "API",
            "defaultValue": "http://localhost:1188/translate",
            "desc": "DeepLX 接口地址，支持填写多个地址，用英文逗号或换行分隔，插件会按顺序自动切换。",
            "textConfig": {
                "type": "visible"
            }
        },
        {
            "identifier": "token",
            "type": "text",
            "title": "Token",
            "desc": "如果你在服务端没有设置，请留空。",
            "defaultValue": ""
        },
        {
            "identifier": "timeout",
            "type": "text",
            "title": "Timeout",
            "desc": "单个接口请求超时时间，单位秒，范围 3-30，默认 8。",
            "defaultValue": "8",
            "textConfig": {
                "type": "visible"
            }
        },
        {
            "identifier": "alternatives",
            "type": "menu",
            "title": "Alternatives",
            "desc": "显示 DeepLX 返回的候选译文。短文本场景常出现多条近似结果，默认关闭。",
            "defaultValue": "2",
            "menuValues": [
                {
                    "title": "开启",
                    "value": "1"
                },
                {
                    "title": "关闭",
                    "value": "2"
                }
            ]
        },
        {
            "identifier": "lineBreakMode",
            "type": "menu",
            "title": "Render Mode",
            "desc": "Smart Paragraphs 会合并 OCR 的碎行；Preserve Formatting 会按原始换行和列表结构显示。",
            "defaultValue": "smart",
            "menuValues": [
                {
                    "title": "Smart Paragraphs",
                    "value": "smart"
                },
                {
                    "title": "Preserve Formatting",
                    "value": "format"
                }
            ]
        }
    ]
}
